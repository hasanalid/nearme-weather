# Server
PORT=3000

# Provider selection (kept configurable so a provider can be swapped later
# without code changes to the routes/services that consume it)
WEATHER_PROVIDER=openmeteo
GEOCODING_PROVIDER=nominatim
PLACES_PROVIDER=overpass
PRODUCT_PROVIDER=openfoodfacts

# Nominatim requires a real, identifying User-Agent per its usage policy —
# put a real app name + contact (email or repo URL) here before deploying.
NOMINATIM_USER_AGENT=NearHalal/1.0 (contact: you@example.com)

# Optional: fetch a restaurant's official website/menu page as supplementary
# halal-verification evidence. Off by default — this performs a live HTTP
# fetch of a third-party site (robots.txt is always checked first and
# honored), so only enable it if you're comfortable with that.
ENABLE_WEB_MENU_CHECK=false

# Caching (in-memory by default — see CacheService for how to swap in Redis)
CACHE_TTL_SECONDS=3600

# Places/search limits, to keep usage of free shared APIs (Nominatim,
# Overpass) reasonable
MAX_SEARCH_RADIUS_METERS=5000
DEFAULT_SEARCH_RADIUS_METERS=3000

# Inbound rate limit: how many requests a single client IP may make to
# our own API per minute (protects the free upstream APIs from being
# hammered via our backend)
API_RATE_LIMIT_PER_MINUTE=60
